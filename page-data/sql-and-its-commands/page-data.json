mote","git-checkout","git-branches","mysql","mariadb","github","github-pages","revert","git-revert","git-reset","git-rebase","regex","windows","pip","pytorch","conda","psycopg2","postgresql","delete-branch","repository","command-line","github.com"],"categoryList":["java","python","javascript","databases","linux","go","html","other","git","ci"],"latestPostEdges":[{"node":{"fields":{"slug":"/abstract-classes-in-java"},"frontmatter":{"template":"post","title":"Abstract Classes in Java","tags":["abstraction","OOP","Class"],"categories":["java"],"date":"2020-11-04 19:58:39 +0100"}}},{"node":{"fields":{"slug":"/map-interface-in-java"},"frontmatter":{"template":"post","title":"Map Interface in Java","tags":["java","collection","API","Map","HashMap","LinkedHashMap","TreeMap"],"categories":["java"],"date":"2020-11-01 14:33:33 +0100"}}},{"node":{"fields":{"slug":"/creating-a-command-line-interface-program-with-argparse"},"frontmatter":{"template":"post","title":"Creating a Command-Line Interface Program With Argparse","tags":["Python","cli","args","argparse"],"categories":["python"],"date":"2020-10-31 19:07:19 -0400"}}},{"node":{"fields":{"slug":"/javascript-arraysort-method"},"frontmatter":{"template":"post","title":"JavaScript Array.sort() Method","tags":["javascript","es6","beginner","codenewbie"],"categories":["javascript"],"date":"2020-10-31 17:50:04 +0100"}}},{"node":{"fields":{"slug":"/primary-key-in-sql"},"frontmatter":{"template":"post","title":"PRIMARY KEY IN SQL","tags":["Primary_key","implementation","Composite_key"],"categories":["databases"],"date":"2020-10-31 17:44:52 +0100"}}},{"node":{"fields":{"slug":"/localization-and-internationalization"},"frontmatter":{"template":"post","title":"Localization and Internationalization","tags":["language-support","localization","internationalization"],"categories":["java"],"date":"2020-10-31 04:49:28 +0530"}}},{"node":{"fields":{"slug":"/linux-file-permissions"},"frontmatter":{"template":"post","title":"Linux File Permissions","tags":["linux","file permissions"],"categories":["linux"],"date":"2020-10-31 01:32:22 -0700"}}},{"node":{"fields":{"slug":"/solving-project-eulers-problem-2-with-python"},"frontmatter":{"template":"post","title":"Solving Project Euler's Problem 2 with Python","tags":["Python","Project Euler","Algortithms"],"categories":["python"],"date":"2020-10-30 23:37:11 +0100"}}}]}},"staticQueryHashes":[]}